
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user data from Firestore profile
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user is Super Admin (checks database role OR future custom claim)
    function isSuperAdmin() {
      return request.auth.token.admin == true || 
             getUserData().role == 'Platform Super Admin' || 
             request.auth.token.email == 'admin@smarterp.ai';
    }

    // Helper: Check if data belongs to user's tenant
    function belongsToTenant(data) {
      return data.tenantId == getUserData().tenantId;
    }
    
    // Helper: Check user role from profile
    function hasRole(roles) {
      let user = getUserData();
      return user.role in roles || user.role == 'Business Owner' || isSuperAdmin();
    }

    // Global multi-tenant access check
    match /{collection}/{docId} {
      // Super Admin can read/write everything. Regular users are isolated by tenantId.
      allow read, write: if isSignedIn() && (isSuperAdmin() || belongsToTenant(resource.data));
      allow create: if isSignedIn() && (isSuperAdmin() || request.resource.data.tenantId != null);
    }

    // Collection Specific Overrides

    // Tenants: Only Super Admins can manage the platform
    match /tenants/{tenantId} {
      allow read: if isSignedIn() && (tenantId == getUserData().tenantId || isSuperAdmin());
      allow write: if isSignedIn() && isSuperAdmin();
    }

    // Users: Users can read their own profile, Owners can read all in tenant
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole(['Business Owner', 'Manager']) || isSuperAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Audit Logs: Append-only for users, Full read for Admins
    match /activity_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (belongsToTenant(resource.data) || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }
    
    // Platform Settings
    match /settings/{setId} {
      allow read: if isSignedIn() && (belongsToTenant(resource.data) || isSuperAdmin());
      allow write: if isSignedIn() && (hasRole(['Business Owner']) || isSuperAdmin());
    }
  }
}
